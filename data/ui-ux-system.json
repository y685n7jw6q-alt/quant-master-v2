{
  "uiUxSystem": {
    "description": "نظام الواجهة والتجربة المستخدم - تصميم شامل للتطبيق",
    "version": "1.0.0",
    "purpose": "توفير واجهة سهلة وفعالة لجميع المستخدمين",
    "designPrinciples": [
      "البساطة والوضوح",
      "سهولة الاستخدام",
      "الاستجابة (Responsive)",
      "الوصول (Accessibility)",
      "الأداء السريع",
      "التصميم الحديث"
    ],
    "userRoles": [
      {
        "role": "طالب",
        "responsibilities": [
          "حل أسئلة",
          "إجراء امتحانات",
          "عرض النتائج",
          "مراجعة الحلول"
        ]
      },
      {
        "role": "مدرس",
        "responsibilities": [
          "إنشاء أسئلة",
          "إدارة الفصول",
          "عرض تقارير الطلاب",
          "تقديم تعليقات"
        ]
      },
      {
        "role": "مسؤول",
        "responsibilities": [
          "إدارة النظام",
          "إدارة المستخدمين",
          "إحصائيات شاملة",
          "إعدادات النظام"
        ]
      }
    ],
    "pages": {
      "landing": {
        "name": "الصفحة الرئيسية",
        "url": "/",
        "sections": [
          {
            "section": "Hero Section",
            "content": {
              "title": "نظام تطوير القدرات الكمية",
              "subtitle": "تعلم وتقيّم نفسك في القدرات الرياضية",
              "cta": "ابدأ الآن",
              "image": "hero-image.png"
            }
          },
          {
            "section": "Features",
            "items": [
              {
                "feature": "أسئلة ذكية",
                "icon": "smart-question",
                "description": "50 سؤال موزعة بذكاء حسب الصعوبة"
              },
              {
                "feature": "تقييم فوري",
                "icon": "instant-feedback",
                "description": "احصل على نتائجك فوراً مع تحليل مفصل"
              },
              {
                "feature": "تقدم شامل",
                "icon": "progress-track",
                "description": "تتبع تقدمك على مدار الزمن"
              },
              {
                "feature": "حلول مفصلة",
                "icon": "detailed-solution",
                "description": "فهم كل خطوة من خطوات الحل"
              }
            ]
          },
          {
            "section": "CTA",
            "content": "سجل الآن واكتشف مستواك"
          }
        ]
      },
      "login": {
        "name": "تسجيل الدخول",
        "url": "/login",
        "components": [
          {
            "component": "Form",
            "fields": [
              {
                "name": "email",
                "label": "البريد الإلكتروني",
                "type": "email",
                "placeholder": "your@email.com",
                "validation": "required|email"
              },
              {
                "name": "password",
                "label": "كلمة المرور",
                "type": "password",
                "placeholder": "••••••••",
                "validation": "required|min:6"
              }
            ]
          },
          {
            "component": "Remember Me",
            "text": "تذكرني"
          },
          {
            "component": "Submit Button",
            "text": "دخول"
          },
          {
            "component": "Links",
            "items": [
              {
                "text": "هل نسيت كلمة المرور؟",
                "url": "/forgot-password"
              },
              {
                "text": "إنشاء حساب جديد",
                "url": "/signup"
              }
            ]
          }
        ]
      },
      "signup": {
        "name": "إنشاء حساب",
        "url": "/signup",
        "components": [
          {
            "component": "Form",
            "fields": [
              {
                "name": "fullname",
                "label": "الاسم الكامل",
                "type": "text",
                "placeholder": "أحمد محمد",
                "validation": "required"
              },
              {
                "name": "email",
                "label": "البريد الإلكتروني",
                "type": "email",
                "placeholder": "your@email.com",
                "validation": "required|email|unique"
              },
              {
                "name": "password",
                "label": "كلمة المرور",
                "type": "password",
                "placeholder": "••••••••",
                "validation": "required|min:8|strong"
              },
              {
                "name": "confirmPassword",
                "label": "تأكيد كلمة المرور",
                "type": "password",
                "placeholder": "••••••••",
                "validation": "required|match:password"
              },
              {
                "name": "userType",
                "label": "نوع المستخدم",
                "type": "select",
                "options": [
                  {"value": "student", "label": "طالب"},
                  {"value": "teacher", "label": "مدرس"}
                ],
                "validation": "required"
              }
            ]
          },
          {
            "component": "Terms",
            "text": "أوافق على الشروط والأحكام"
          },
          {
            "component": "Submit Button",
            "text": "إنشاء حساب"
          }
        ]
      },
