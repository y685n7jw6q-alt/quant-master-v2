    "components": {
      "buttons": [
        {
          "type": "primary",
          "label": "ابدأ",
          "size": "medium",
          "icon": "play"
        },
        {
          "type": "secondary",
          "label": "إلغاء",
          "size": "medium",
          "icon": null
        },
        {
          "type": "danger",
          "label": "حذف",
          "size": "small",
          "icon": "trash"
        }
      ],
      "forms": [
        {
          "type": "text input",
          "validation": "live",
