{
  "reviewAndImprovementSystem": {
    "description": "نظام المراجعة والتحسين المستمر للأسئلة",
    "version": "1.0.0",
    "objective": "ضمان جودة الأسئلة بشكل مستمر من خلال المراجعة والتحليل والتحسين",
    "phases": {
      "phase1": {
        "name": "مرحلة المراجعة العلمية",
        "description": "التحقق من صحة المحتوى الرياضي",
        "steps": [
          {
            "step": 1,
            "name": "التحقق من الصيغة الرياضية",
            "checklist": [
              "✓ هل الصيغة صحيحة رياضياً؟",
              "✓ هل جميع الخطوات واضحة؟",
              "✓ هل الحساب صحيح؟",
              "✓ هل تم استخدام الوحدات بشكل صحيح؟"
            ]
          },
          {
            "step": 2,
            "name": "التحقق من الإجابة الصحيحة",
            "checklist": [
              "✓ هل الإجابة صحيحة؟",
              "✓ هل تم حسابها بطريقة أخرى للتأكد؟",
              "✓ هل هناك أكثر من إجابة صحيحة؟",
              "✓ هل الإجابة معقولة ضمن السياق؟"
            ]
          },
          {
            "step": 3,
            "name": "التحقق من الخيارات الخاطئة",
            "checklist": [
              "✓ هل تمثل أخطاء شائعة فعلاً؟",
              "✓ هل جميع الخيارات مختلفة عن بعضها؟",
              "✓ هل هناك خيار واحد فقط صحيح؟",
              "✓ هل الخيارات مقنعة للطلاب الضعفاء؟"
            ]
          }
        ]
      },
      "phase2": {
        "name": "مرحلة المراجعة اللغوية",
        "description": "التحقق من صحة ووضوح النص العربي",
        "steps": [
          {
            "step": 1,
            "name": "المراجعة الإملائية والنحوية",
            "checklist": [
              "✓ هل النص خالي من الأخطاء الإملائية؟",
              "✓ هل الجمل سليمة نحوياً؟",
              "✓ هل الترقيم صحيح؟",
              "✓ هل استخدام اللغة احترافي؟"
            ]
          },
          {
            "step": 2,
            "name": "وضوح المعنى",
            "checklist": [
              "✓ هل السؤال واضح لا يحتمل تفسيرات أخرى؟",
              "✓ هل المطلوب محدد وواضح؟",
              "✓ هل جميع المعطيات موجودة؟",
              "✓ هل الصياغة بسيطة وسهلة الفهم؟"
            ]
          },
          {
            "step": 3,
            "name": "مطابقة أسلوب القدرات",
            "checklist": [
              "✓ هل نمط السؤال يطابق اختبار القدرات؟",
              "✓ هل المصطلحات المستخدمة موحدة؟",
              "✓ هل الصياغة احترافية؟",
              "✓ هل السياق ثقافياً مناسب؟"
            ]
          }
        ]
      },
      "phase3": {
        "name": "مرحلة الاختبار الفني",
        "description": "اختبار السؤال عملياً قبل النشر",
        "steps": [
          {
            "step": 1,
            "name": "اختبار التنسيق",
            "checklist": [
              "✓ هل الأرقام منسقة بشكل صحيح؟",
              "✓ هل الكسور معروضة بشكل صحيح؟",
              "✓ هل الوحدات واضحة؟",
              "✓ هل الجداول والرسوم البيانية صحيحة؟"
            ]
          },
          {
            "step": 2,
            "name": "اختبار الخيارات",
            "checklist": [
              "✓ هل جميع الخيارات مرئية بوضوح؟",
              "✓ هل أطوال الخيارات متنوعة؟",
              "✓ هل لا يوجد تسرب للإجابة الصحيحة؟",
              "✓ هل الترتيب عشوائي؟"
            ]
          },
          {
            "step": 3,
            "name": "اختبار الحل",
            "checklist": [
              "✓ هل الحل يمكن فهمه من قبل الطلاب؟",
              "✓ هل جميع الخطوات واضحة؟",
              "✓ هل يوجد معلومات إضافية مفيدة؟",
              "✓ هل النصائح عملية وقابلة للتطبيق؟"
            ]
          }
        ]
      }
    },
    "performanceAnalysis": {
      "description": "تحليل أداء السؤال بعد استخدامه مع الطلاب",
      "metrics": [
        {
          "metric": "Success Rate (SR)",
          "formula": "(عدد الإجابات الصحيحة / إجمالي المحاولات) × 100",
          "interpretation": {
            "excellent": "85-95%: السؤال مناسب للمستوى",
            "good": "70-85%: السؤال جيد",
            "moderate": "50-70%: السؤال متوسط الصعوبة",
            "difficult": "30-50%: السؤال صعب",
            "tooHard": "< 30%: السؤال صعب جداً"
          },
          "action": {
            "tooHigh": "إذا > 95%: قد يكون السؤال سهل جداً",
            "tooLow": "إذا < 20%: قد يكون السؤال غير واضح أو صعب جداً"
          }
        },
        {
          "metric": "Average Time (AT)",
          "formula": "متوسط الزمن المستغرق للإجابة",
          "expectedTime": {
            "foundation": "30-60 ثانية",
            "basic": "60-120 ثانية",
            "intermediate": "120-180 ثانية",
            "advanced": "180-300 ثانية",
            "qudrat": "240-360 ثانية"
          },
          "insight": "إذا كان الزمن أقل من المتوقع: قد يكون السؤال سهل"
        },
        {
          "metric": "Discrimination Index (DI)",
          "formula": "(نسبة نجاح الطلاب الأقوياء - نسبة نجاح الضعفاء)",
          "threshold": "> 0.3 يعني السؤال جيد للتفريق",
          "interpretation": {
            "excellent": "> 0.4: تفريق ممتاز",
            "good": "0.3-0.4: تفريق جيد",
            "acceptable": "0.1-0.3: تفريق مقبول",
            "poor": "< 0.1: تفريق ضعيف"
          }
        },
        {
          "metric": "Most Common Wrong Answer (MCWA)",
          "description": "أكثر خيار خاطئ يتم اختياره",
          "insight": "إذا اختار 40% من الطلاب نفس الخيار الخاطئ: قد يكون السؤال غير واضح"
        },
        {
          "metric": "Question Difficulty Index (QDI)",
          "formula": "(عدد الأسئلة الصحيحة - عدد الخاطئة) / إجمالي الأسئلة",
          "scale": "من -1 (الكل خطأ) إلى +1 (الكل صحيح)",
          "action": "استخدم هذا المؤشر لضبط مستوى الصعوبة"
        }
      ]
    },
