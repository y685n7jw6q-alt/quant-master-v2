      "slideInRight": {
        "keyframes": "0% { transform: translateX(20px); opacity: 0 } 100% { transform: translateX(0); opacity: 1 }",
        "duration": "0.4s",
        "easing": "ease-out"
      },
      "slideInLeft": {
        "keyframes": "0% { transform: translateX(-20px); opacity: 0 } 100% { transform: translateX(0); opacity: 1 }",
        "duration": "0.4s",
        "easing": "ease-out"
      },
      "pulse": {
        "keyframes": "0%, 100% { opacity: 1 } 50% { opacity: 0.5 }",
        "duration": "2s",
        "easing": "ease-in-out",
        "iteration": "infinite"
      },
      "bounce": {
        "keyframes": "0%, 100% { transform: translateY(0) } 50% { transform: translateY(-10px) }",
        "duration": "1s",
        "easing": "ease-in-out",
        "iteration": "infinite"
      },
      "scale": {
        "keyframes": "0% { transform: scale(0.95) } 100% { transform: scale(1) }",
        "duration": "0.2s",
        "easing": "ease-out"
      }
